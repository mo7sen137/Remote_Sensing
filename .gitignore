# Gitignore for Remote Sensing Project

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/

# Data files (large)
*.tif
*.tiff
data/sample_landsat/*.TIF
data/sample_landsat/*.tif

# Large model files (optional - might want to exclude)
# models/*.pkl
# models/*.joblib

# Temporary files
*.tmp
tmp/
/tmp/*
tempfile*

# OS
.DS_Store
Thumbs.db
.env

# Outputs
data/outputs/*.png
data/outputs/*.csv
data/outputs/*.json

# Streamlit
.streamlit/secrets.toml

# Logs
*.log
logs/

# Cache
.cache
*.cache

# Editor backups
*.backup
*.bak
